{
  "version": "1.0",
  "name": "todo-app-feature-verification",
  "expires": "2026-03-01T00:00:00Z",

  "limits": {
    "maxSpendUSD": {
      "value": 10.00,
      "enforcement": "fail-fast"
    },
    "maxTokensIn": {
      "value": 300000,
      "enforcement": "fail-fast"
    },
    "maxTokensOut": {
      "value": 75000,
      "enforcement": "post-hoc"
    },
    "maxTurns": {
      "value": 30,
      "enforcement": "post-hoc"
    },
    "maxWallTimeSeconds": {
      "value": 1800,
      "enforcement": "fail-fast"
    },
    "maxToolCalls": {
      "value": 150,
      "enforcement": "post-hoc"
    }
  },

  "tools": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash",
      "LSP",
      "Task"
    ],
    "deny": [],
    "requireApproval": [
      "Bash:rm -rf *",
      "Bash:git push --force*",
      "Write:*.env*",
      "Write:*credentials*"
    ]
  },

  "files": {
    "allow": [
      "src/**",
      "tests/**",
      "e2e/**",
      "cypress/**",
      "playwright/**",
      "screenshots/**",
      "package.json",
      "tsconfig.json",
      "jest.config.*",
      "playwright.config.*",
      "cypress.config.*"
    ],
    "deny": [
      "**/.env",
      "**/.env.*",
      "**/secrets/**",
      "**/credentials.*",
      "**/node_modules/**"
    ],
    "readOnly": [
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml"
    ]
  },

  "domains": {
    "allow": [
      "github.com",
      "npmjs.com",
      "registry.npmjs.org",
      "*.anthropic.com",
      "localhost",
      "127.0.0.1"
    ],
    "deny": [
      "*"
    ]
  },

  "requiredAttestations": [
    "unit-tests",
    "integration-tests",
    "e2e-tests",
    "uat-screenshots"
  ],

  "attestationDir": "./attestations/todo-app",

  "attestationsFrom": [
    "turn-*",
    "test-*",
    "uat-*"
  ],

  "materialsFrom": {
    "session": {
      "path": "${CLAUDE_SESSION_PATH}",
      "algorithm": "sha256",
      "constraints": {
        "maxTurnDistance": 5,
        "requireContiguousTurns": true
      }
    },
    "git": {
      "treeHash": "${GIT_TREE_HASH}",
      "branch": "${GIT_BRANCH}"
    },
    "artifacts": [
      {
        "name": "test-results-unit",
        "digest": { "sha256": "${UNIT_TEST_HASH}" },
        "uri": "file://./coverage/junit.xml"
      },
      {
        "name": "test-results-e2e",
        "digest": { "sha256": "${E2E_TEST_HASH}" },
        "uri": "file://./e2e-results/results.json"
      },
      {
        "name": "uat-screenshots",
        "digest": { "sha256": "${SCREENSHOTS_HASH}" },
        "uri": "file://./screenshots/"
      }
    ]
  },

  "evaluators": {
    "rego": [
      {
        "name": "all-tests-passed",
        "policy": "package todoapp\n\nimport rego.v1\n\n# Collect test attestations\ntest_attestations := [t | some t in input.attestationsFrom[\"test-*\"]]\n\n# Check all tests passed\nfailed_tests := [t | some t in test_attestations; t.predicate.exitCode != 0]\n\n# Deny if any tests failed\ndeny contains msg if {\n    count(failed_tests) > 0\n    msg := sprintf(\"Failed test suites: %d\", [count(failed_tests)])\n}"
      },
      {
        "name": "cumulative-spend-check",
        "policy": "package todoapp\n\nimport rego.v1\n\n# Access all turn attestations\nturns := [t | some t in input.attestationsFrom[\"turn-*\"]]\n\n# Sum all costs\nsum_spend := sum([t.predicate.metrics.costUSD | some t in turns])\n\n# Check against limit\ndeny contains msg if {\n    sum_spend > input.policy.limits.maxSpendUSD.value\n    msg := sprintf(\"Cumulative spend $%.2f exceeds limit $%.2f\", [sum_spend, input.policy.limits.maxSpendUSD.value])\n}"
      },
      {
        "name": "screenshots-captured",
        "policy": "package todoapp\n\nimport rego.v1\n\n# Check that UAT screenshots were captured\nuat_attestations := [t | some t in input.attestationsFrom[\"uat-*\"]]\n\n# Required screenshot scenarios\nrequired_scenarios := {\"add-todo\", \"complete-todo\", \"delete-todo\", \"filter-todos\"}\n\n# Captured scenarios\ncaptured_scenarios := {s | some t in uat_attestations; s := t.predicate.scenario}\n\n# Find missing scenarios\nmissing := required_scenarios - captured_scenarios\n\n# Deny if any screenshots missing\ndeny contains msg if {\n    count(missing) > 0\n    msg := sprintf(\"Missing UAT screenshots: %v\", [missing])\n}"
      }
    ],
    "ai": [
      {
        "name": "test-coverage-quality",
        "prompt": "You are evaluating the test suite for a Todo application. Review the test attestations and code changes.\n\nPASS criteria (ALL must be met):\n1. Unit tests cover the main CRUD operations (Create, Read, Update, Delete todos)\n2. Integration tests verify API endpoints respond correctly\n3. E2E tests simulate real user flows\n4. Test assertions are meaningful (not just checking existence)\n5. Edge cases are covered (empty list, max length, special characters)\n\nFAIL if:\n- Any CRUD operation lacks test coverage\n- Tests only check happy paths with no error handling tests\n- Test assertions are trivial (e.g., only checking true/false)\n- No E2E tests for complete user workflows\n\nRespond with PASS or FAIL followed by a brief explanation.",
        "model": "claude-sonnet-4-20250514"
      },
      {
        "name": "screenshot-verification",
        "prompt": "You are verifying UAT screenshots for a Todo application. Review all captured screenshots.\n\nPASS criteria (ALL must be met):\n1. 'add-todo' screenshot shows: empty input, typing text, todo appearing in list\n2. 'complete-todo' screenshot shows: unchecked todo, clicking checkbox, todo marked complete with strikethrough\n3. 'delete-todo' screenshot shows: existing todo, clicking delete button, todo removed from list\n4. 'filter-todos' screenshot shows: mixed complete/incomplete todos, filter buttons, filtered view\n\nFAIL if:\n- Any required scenario is missing or incomplete\n- Screenshots don't clearly show the action being performed\n- UI elements are not visible or cut off\n- State change is not apparent before/after\n\nRespond with PASS or FAIL followed by a brief explanation.",
        "model": "claude-opus-4-5-20251101"
      },
      {
        "name": "code-quality",
        "prompt": "You are reviewing code quality for a Todo application implementation. Examine the code changes.\n\nPASS criteria (ALL must be met):\n1. Code follows consistent naming conventions\n2. Functions are reasonably sized (< 50 lines)\n3. Error handling is present for user inputs\n4. No obvious security issues (XSS, injection)\n5. State management is predictable (no race conditions)\n\nFAIL if:\n- Functions exceed 50 lines without good reason\n- User input is not sanitized or validated\n- State mutations are scattered and unpredictable\n- Obvious security vulnerabilities exist\n- Code has TODO comments for critical functionality\n\nRespond with PASS or FAIL followed by a brief explanation.",
        "model": "claude-sonnet-4-20250514"
      }
    ]
  },

  "functionaries": [
    {
      "type": "keyless",
      "issuer": "https://accounts.google.com",
      "subject": "developer@example.com"
    },
    {
      "type": "keyless",
      "issuer": "https://token.actions.githubusercontent.com",
      "subject": "https://github.com/myorg/todo-app/.github/workflows/ci.yml@refs/heads/main"
    }
  ]
}
